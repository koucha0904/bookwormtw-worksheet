---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorksheetCard from '../../components/WorksheetCard.astro';
import { t, localizedPath, type Lang, ui } from '../../i18n/ui';
import { organizationJsonLd, websiteJsonLd } from '../../lib/seo';

export async function getStaticPaths() {
  return [{ params: { lang: 'zh' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const allWorksheets = await getCollection('worksheets', (w) => w.data.lang === lang);
const allTopics = await getCollection('topics', (t) => t.data.lang === lang);
const topicMap = new Map(allTopics.map((t) => [t.id, t.data]));

const featured = allWorksheets
  .filter((w) => w.data.featured)
  .sort((a, b) => +b.data.publishedAt - +a.data.publishedAt)
  .slice(0, 4);

const topicsWithCount = allTopics
  .map((t) => ({
    ...t.data,
    count: allWorksheets.filter((w) => w.data.topic.id === t.id).length,
  }))
  .sort((a, b) => a.order - b.order);

const siteName = ui[lang]['site.name'];
const title = `${siteName} — ${t(lang, 'site.tagline')}`;
const canonical = localizedPath(lang, '/');
const altLang: Lang = lang === 'zh' ? 'en' : 'zh';
---

<BaseLayout
  lang={lang}
  title={title}
  description={t(lang, 'site.description')}
  canonical={canonical}
  altLangPath={localizedPath(altLang, '/')}
  alternates={[
    { lang: 'zh', href: '/zh' },
    { lang: 'en', href: '/en' },
  ]}
  jsonLd={[organizationJsonLd(lang), websiteJsonLd(lang)]}
>
  <section class="max-w-6xl mx-auto px-5 pt-12 pb-10 md:pt-20 md:pb-14">
    <div class="max-w-3xl">
      <p class="text-brand-500 text-sm uppercase tracking-widest mb-3">{t(lang, 'site.tagline')}</p>
      <h1 class="font-display text-4xl md:text-6xl leading-tight text-brand-900">
        {t(lang, 'home.hero.title')}
      </h1>
      <p class="mt-5 text-lg text-brand-700 leading-relaxed">
        {t(lang, 'home.hero.subtitle')}
      </p>
      <div class="mt-7">
        <a href={localizedPath(lang, '/worksheets')}
           class="inline-block px-6 py-3 rounded-full bg-brand-700 text-white hover:bg-brand-800 font-medium">
          {t(lang, 'home.hero.cta')} →
        </a>
      </div>
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-8">
    <div class="flex items-end justify-between mb-6">
      <h2 class="font-display text-2xl md:text-3xl text-brand-900">{t(lang, 'home.featured.title')}</h2>
      <a href={localizedPath(lang, '/worksheets')} class="text-sm text-brand-600 hover:text-brand-800">
        {t(lang, 'nav.worksheets')} →
      </a>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {featured.map((w) => {
        const topic = topicMap.get(w.data.topic.id);
        const cleanSlug = w.data.worksheetSlug;
        return (
          <WorksheetCard
            lang={lang}
            slug={cleanSlug}
            title={w.data.title}
            description={w.data.description}
            grade={w.data.grade}
            coverEmoji={w.data.coverEmoji}
            coverColor={w.data.coverColor}
            topicTitle={topic?.title ?? ''}
          />
        );
      })}
    </div>
  </section>

  <section class="max-w-6xl mx-auto px-5 py-10">
    <h2 class="font-display text-2xl md:text-3xl text-brand-900 mb-6">{t(lang, 'home.topics.title')}</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {topicsWithCount.map((topic) => (
        <a href={localizedPath(lang, `/topics/${topic.slug.replace(/-en$/, '')}`)}
           class="flex items-center gap-5 p-5 rounded-2xl bg-white border border-brand-100 hover:border-brand-300 hover:shadow transition">
          <div class="text-4xl">{topic.emoji}</div>
          <div class="flex-1">
            <h3 class="font-display text-xl text-brand-900">{topic.title}</h3>
            <p class="text-sm text-brand-600 mt-1">{topic.description}</p>
            <p class="text-xs text-brand-500 mt-2">{t(lang, 'topics.count', { count: topic.count })}</p>
          </div>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-5 py-14 text-center">
    <h2 class="font-display text-2xl md:text-3xl text-brand-900 mb-4">{t(lang, 'home.about.title')}</h2>
    <p class="text-brand-700 leading-relaxed">{t(lang, 'home.about.body')}</p>
  </section>
</BaseLayout>
