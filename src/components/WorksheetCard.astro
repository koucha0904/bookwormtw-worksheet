---
import type { Lang } from '../i18n/ui';
import { t, localizedPath } from '../i18n/ui';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  description: string;
  grade: 'lower' | 'middle' | 'upper' | 'all';
  coverEmoji: string;
  coverColor: string;
  topicTitle: string;
}

const { lang, slug, title, description, grade, coverEmoji, coverColor, topicTitle } = Astro.props;
const href = localizedPath(lang, `/worksheets/${slug}`);
---

<a href={href} class="group block rounded-2xl overflow-hidden bg-white border border-brand-100 hover:border-brand-300 hover:shadow-lg transition">
  <div class="aspect-[5/3] flex items-center justify-center" style={`background-color: ${coverColor}`}>
    <span class="text-6xl transition group-hover:scale-110">{coverEmoji}</span>
  </div>
  <div class="p-5">
    <div class="flex items-center gap-2 text-xs text-brand-500 mb-1.5">
      <span>{topicTitle}</span>
      <span>·</span>
      <span>{t(lang, `grade.${grade}` as `grade.lower`)}</span>
    </div>
    <h3 class="font-display text-lg text-brand-900 group-hover:text-brand-700 leading-snug">
      {title}
    </h3>
    <p class="text-sm text-brand-600 mt-2 line-clamp-2">{description}</p>
  </div>
</a>
