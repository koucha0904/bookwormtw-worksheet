---
import type { Lang } from '../i18n/ui';
import { ui } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang: Lang;
  canonical: string;
  alternates?: Array<{ lang: Lang; href: string }>;
  ogType?: 'website' | 'article';
  ogImage?: string;
  jsonLd?: object | object[];
  publishedAt?: Date;
  updatedAt?: Date;
}

const {
  title,
  description,
  lang,
  canonical,
  alternates = [],
  ogType = 'website',
  ogImage,
  jsonLd,
  publishedAt,
  updatedAt,
} = Astro.props;

const siteName = ui[lang]['site.name'];
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
const htmlLang = lang === 'zh' ? 'zh-TW' : 'en';
const ogLocale = lang === 'zh' ? 'zh_TW' : 'en_US';
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const absCanonical = canonical.startsWith('http') ? canonical : `${siteUrl}${canonical}`;
const absOgImage = ogImage
  ? ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`
  : `${siteUrl}/og-default.png`;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta http-equiv="x-ua-compatible" content="IE=edge" />

<title>{fullTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={absCanonical} />

<meta property="og:type" content={ogType} />
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={absCanonical} />
<meta property="og:site_name" content={siteName} />
<meta property="og:locale" content={ogLocale} />
<meta property="og:image" content={absOgImage} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={absOgImage} />

{publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
{updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}

{alternates.map((alt) => (
  <link rel="alternate" hreflang={alt.lang === 'zh' ? 'zh-TW' : alt.lang} href={alt.href.startsWith('http') ? alt.href : `${siteUrl}${alt.href}`} />
))}
{alternates.length > 0 && (
  <link rel="alternate" hreflang="x-default" href={alternates.find((a) => a.lang === 'en')?.href
    ? (alternates.find((a) => a.lang === 'en')!.href.startsWith('http')
      ? alternates.find((a) => a.lang === 'en')!.href
      : `${siteUrl}${alternates.find((a) => a.lang === 'en')!.href}`)
    : absCanonical} />
)}

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,700&family=Noto+Sans+TC:wght@400;500;700&family=Noto+Serif+TC:wght@500;700&display=swap" rel="stylesheet" />

{jsonLdArray.map((data) => (
  <script type="application/ld+json" set:html={JSON.stringify(data)} is:inline />
))}
